# Copy this file to the root of your Railway project and fill in the values
# These will be imported into both API and Web services

# ============================================================
# BACKEND API ENVIRONMENT VARIABLES
# These go in the API service settings on Railway
# ============================================================

# Node Environment
NODE_ENV=production
PORT=3000

# Database Connection
# Get these values from Railway's PostgreSQL service
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Example: postgresql://postgres:abc123@db-production-xxxx.railway.internal:5432/railway
DATABASE_URL=postgresql://user:password@host:5432/visitour

# JWT Token Secret (IMPORTANT: Use a strong random string)
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-64-character-random-hex-string-here-change-this-to-something-secure

# CORS Configuration
# Set this to your deployed web app domain
CORS_ORIGIN=https://web-production-xxxx.railway.app

# API URL (for linking references)
API_URL=https://api-production-xxxx.railway.app

# ============================================================
# WEB APP ENVIRONMENT VARIABLES
# These go in the Web service settings on Railway
# Note: MUST be prefixed with VITE_ for Vite to pick them up
# ============================================================

# API Endpoint (Web app will use this to call the API)
VITE_API_URL=https://api-production-xxxx.railway.app

# WebSocket Server (same as API for Socket.io)
VITE_API_SOCKET_URL=https://api-production-xxxx.railway.app

# ============================================================
# OPTIONAL: Advanced Configuration
# ============================================================

# Enable debug logging (development only)
DEBUG=visitour:*

# API Rate Limiting (if implemented)
RATE_LIMIT_WINDOW=15m
RATE_LIMIT_MAX_REQUESTS=100

# Session Timeout (in hours)
SESSION_TIMEOUT=24

# Email Configuration (if you add email verification later)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password

# ============================================================
# INSTRUCTIONS FOR RAILWAY DEPLOYMENT
# ============================================================

# 1. DO NOT commit this file with real values
# 2. In Railway Dashboard:
#    - Go to API Service → Variables
#    - Add each line from "BACKEND API ENVIRONMENT VARIABLES"
#    - Do the same for Web Service with sections starting with "VITE_"
# 3. For DATABASE_URL:
#    - Connect your PostgreSQL service to Railway
#    - Copy the connection string from PostgreSQL service
#    - Paste it here
# 4. For JWT_SECRET, generate a new one:
#    - Open terminal: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#    - Copy the output and use as JWT_SECRET

# ============================================================
# RAILWAY DOMAINS (You'll get these after first deploy)
# ============================================================

# After deploying to Railway, you'll get auto-generated domains:
# API will be: https://api-production-xxxxx.railway.app
# Web will be: https://web-production-xxxxx.railway.app

# Update your environment variables to use these actual domains!
# Then trigger a re-deploy so both services have correct URLs

# ============================================================
# TESTING YOUR DEPLOYMENT
# ============================================================

# Once deployed, test with:

# 1. API Health Check
# curl https://your-api-domain.railway.app/api/health
# Should return: {"status":"ok","timestamp":"..."}

# 2. Open Web App in Browser
# https://your-web-domain.railway.app
# Should show Visitour homepage

# 3. Test Registration
# Click "Register", create account, try logging in

# 4. Test Real-time Features
# Open two browser windows, create itinerary in one
# Should appear in real-time in the other (WebSocket)

# ============================================================

