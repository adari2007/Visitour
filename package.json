{
  "name": "visitour",
  "version": "1.0.0",
  "description": "Cross-platform itinerary application",
  "private": true,
  "scripts": {
    "dev": "yarn dev:web",
    "dev:web": "yarn workspace @visitour/web dev",
    "dev:mobile": "yarn workspace @visitour/mobile start",
    "build": "yarn build:web && yarn build:mobile",
    "build:web": "yarn workspace @visitour/web build",
    "build:mobile": "yarn workspace @visitour/mobile build",
    "lint": "yarn workspaces foreach run lint",
    "type-check": "yarn workspaces foreach run type-check",
    "test": "yarn workspaces foreach run test",
    "format": "prettier --write \"apps/**/*.{ts,tsx,js,jsx,json,css}\" \"packages/**/*.{ts,tsx,js,jsx,json,css}\""
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0"
  },
  "packageManager": "yarn@4.14.1"
}
