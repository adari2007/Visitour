# API Environment Variables
#
# Environment file precedence (highest -> lowest):
# 1) .env.<NODE_ENV>.local
# 2) .env.local
# 3) .env.<NODE_ENV>
# 4) .env
#
# Example: use .env.development for local dev and .env.production for production-like runs.
PORT=3000
NODE_ENV=development

# Database (set either DATABASE_URL or the discrete fields below)
DATABASE_URL=postgresql://postgres:password@localhost:5432/visitour
# Optional SSL settings (recommended for hosted databases like Railway)
# DB_SSL=true
# DB_SSL_REJECT_UNAUTHORIZED=false
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_USER=postgres
# DATABASE_PASSWORD=your-password
# DATABASE_NAME=visitour
DB_SCHEMA=visitour_dev

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=7d

# CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:19000

# WebSocket
WS_URL=http://localhost:3000
